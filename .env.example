# ORACLE Environment Configuration

# Data directories
DATA_DIR=./data
OUTPUT_DIR=./outputs
LOG_DIR=./logs
CHECKPOINT_DIR=./checkpoints
CACHE_DIR=./cache

# External tool paths
FPOCKET_PATH=/usr/local/bin/fpocket

# API keys (optional — public APIs work without these)
# ALPHAFOLD_API_KEY=
# CHEMBL_API_KEY=

# Compute
ORACLE_DEVICE=mps
ORACLE_N_JOBS=8
